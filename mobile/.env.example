# VocalAIze Mobile Environment Variables

# API Configuration
EXPO_PUBLIC_API_URL=http://localhost:8000
EXPO_PUBLIC_WS_URL=ws://localhost:8000/ws

# Feature Flags
EXPO_PUBLIC_ENABLE_VOICE=true
EXPO_PUBLIC_ENABLE_BIOMETRICS=true
EXPO_PUBLIC_ENABLE_NOTIFICATIONS=true

# Analytics (Optional)
EXPO_PUBLIC_ANALYTICS_ID=

# Sentry (Optional)
SENTRY_DSN=
